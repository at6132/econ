[gd_scene load_steps=5 format=3 uid="uid://realm_atmosphere"]

[ext_resource type="Script" path="res://scenes/AtmosphereOverlay.gd" id="1_script"]

[sub_resource type="Shader" id="Shader_scan"]
code = "shader_type canvas_item;
void fragment() {
	float line = step(0.5, fract(UV.y * 300.0));
	COLOR = vec4(0.0, 0.0, 0.0, line * 0.07);
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_scan"]
shader = SubResource("Shader_scan")

[sub_resource type="Shader" id="Shader_vig"]
code = "shader_type canvas_item;
void fragment() {
	vec2 uv = UV * 2.0 - 1.0;
	float d = dot(uv, uv);
	float v = smoothstep(0.2, 1.1, d);
	COLOR = vec4(0.0, 0.0, 0.0, v * 0.18);
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_vig"]
shader = SubResource("Shader_vig")

